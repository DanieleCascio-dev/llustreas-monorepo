APP_NAME=IllustreasAPI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=aws-1-eu-central-1.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

FRONTEND_URL=http://localhost:5173
BACKOFFICE_URL=http://localhost:5174

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:5174,localhost:8000
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false

# Production example:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://api.letiziaragionedesign.com
# SESSION_DRIVER=cookie
# SESSION_DOMAIN=.letiziaragionedesign.com
# SESSION_SECURE_COOKIE=true
# FRONTEND_URL=https://letiziaragionedesign.com
# BACKOFFICE_URL=https://admin.letiziaragionedesign.com
# SANCTUM_STATEFUL_DOMAINS=admin.letiziaragionedesign.com,letiziaragionedesign.com
